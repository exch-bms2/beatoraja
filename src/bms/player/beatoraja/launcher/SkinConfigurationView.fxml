<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" xmlns="http://javafx.com/javafx/8.0.65" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bms.player.beatoraja.launcher.SkinConfigurationView">
    <VBox spacing="4.0" styleClass="pageHeader">
        <Label styleClass="pageTitle" text="Skin" />
        <Label styleClass="pageDescription" text="Choose a skin and customize its presentation options." />
    </VBox>
    <VBox styleClass="settingsCard">
        <Label styleClass="cardTitle" text="Active Skin" />
        <HBox alignment="CENTER_LEFT" styleClass="settingRow">
            <Label styleClass="settingLabel" text="%Category" /><Region HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="skintypeSelector" onAction="#changeSkinType" prefWidth="230.0" />
        </HBox>
        <HBox alignment="CENTER_LEFT" styleClass="settingRow,last">
            <Label styleClass="settingLabel" text="%Skin" /><Region HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="skinheaderSelector" onAction="#changeSkinHeader" prefWidth="340.0" />
            <Button mnemonicParsing="false" onAction="#commitSkinType" text="%Update" />
        </HBox>
    </VBox>
    <ScrollPane fx:id="skinconfig" fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
        <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="200.0" prefWidth="200.0" />
    </ScrollPane>
</VBox>
